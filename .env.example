# ───────────────────────────────────────────────────────────────
# Unbound Studio — 환경변수 예시
# 이 파일을 복사해서 `.env.local` 로 만들고 실제 값을 채워주세요.
#   cp .env.example .env.local
# `.env.local` 은 git에 올라가지 않습니다(.gitignore). 절대 커밋하지 마세요.
# 실제 운영 값은 Vercel 프로젝트 → Settings → Environment Variables 에 등록되어 있습니다.
# ───────────────────────────────────────────────────────────────

# [문의 폼 메일 발송] Resend API 키 — https://resend.com 대시보드에서 발급
# 없으면 /contact 폼 제출 시 "서버 설정 오류"가 납니다.
RESEND_API_KEY=

# [관리자 빌더(/admin) 저장소] Upstash Redis (= Vercel KV)
# https://upstash.com 또는 Vercel → Storage 에서 생성 후 값 복사
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (대체 변수명도 지원됨 — 둘 중 하나만 채우면 됨)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# [관리자 로그인(/admin)] 빌더 접근 비밀번호 + 세션 서명용 시크릿
ADMIN_PASSWORD=
# 아무 랜덤 문자열(길수록 좋음). 예: openssl rand -hex 32
ADMIN_SESSION_SECRET=
